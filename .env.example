# Copy this file to .env and adjust values for your host, then run:
#   docker compose up -d
# .env is read automatically by Docker Compose — no need to pass --env-file.

# --- Serial modem (api only) ---------------------------------------------
SERIAL_DEVICE=/dev/ttyUSB2
SERIAL_PORT=/dev/COM1

# --- Host port bindings ----------------------------------------------------
API_PORT=5000
WEB_PORT=8080

# --- Shared secret -----------------------------------------------------------
# Must match between api (Security:MasterKey) and web (SmsService:MasterKey).
# Generate a fresh one for production, e.g.: uuidgen
MASTER_KEY=replace-with-a-generated-guid

# --- Runtime environment -----------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
